{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],

    "redirects": [
      {
        "source": "**",
        "has": [
          { "type": "host", "value": "pinellastow.com" }
        ],
        "destination": "https://blackjacktowingfl.com/:path*",
        "type": 301
      },
      {
        "source": "**",
        "has": [
          { "type": "host", "value": "www.pinellastow.com" }
        ],
        "destination": "https://blackjacktowingfl.com/:path*",
        "type": 301
      },
      {
        "source": "**",
        "has": [
          { "type": "host", "value": "towboysfl.com" }
        ],
        "destination": "https://blackjacktowingfl.com/:path*",
        "type": 301
      },
      {
        "source": "**",
        "has": [
          { "type": "host", "value": "www.towboysfl.com" }
        ],
        "destination": "https://blackjacktowingfl.com/:path*",
        "type": 301
      }
    ],

    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
